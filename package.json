{
  "name": "jessehouwing-vsts-variable-tasks",
  "version": "3.0.0",
  "description": "Azure Pipelines Variable Toolbox",
  "repository": {
    "type": "git",
    "url": "https://github.com/jessehouwing/azure-pipelines-variable-tasks.git"
  },
  "keywords": [
    "vsts",
    "tfs",
    "azure-devops",
    "azure-pipelines"
  ],
  "workspaces": [
    "vsts-variable-set/v1",
    "vsts-variable-set/v2",
    "vsts-variable-set/v3",
    "vsts-variable-transform/v1",
    "vsts-variable-transform/v2",
    "vsts-variable-transform/v3"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:clean": "npm run clean && npm install --legacy-peer-deps && npm run build",
    "package:tasks": "tfx extension create --root . --output-path dist --manifest-globs vss-extension.json",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage",
    "test:pester": "pwsh -Command \"Invoke-Pester -Path './vsts-variable-*' -Output Detailed\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "git clean -fdX"
  },
  "author": "Jesse Houwing",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "rollup": "^4.62.2",
    "tfx-cli": "^0.23.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
